# ── Подключение к LLM (по умолчанию для локального Ollama) ────────────────────
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=ollama
LLM_TIMEOUT=300.0
LLM_MAX_TOKENS=16384
LLM_NUM_CTX=16384

# ── Пути и логирование ───────────────────────────────────────────────────────
PROJECT_BASE_DIR=/path/to/your/projects
LOG_LEVEL=INFO

# ── Облачные API ключи (заполни нужные) ──────────────────────────────────────
# Рабочий GPUstack (python ai_factory.py --cloud work)
WORK_API_KEY=
# Groq (python ai_factory.py --cloud groq)
# Получить: https://console.groq.com/keys
GROQ_API_KEY=
# OpenRouter (python ai_factory.py --cloud openrouter)
# Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# SiliconFlow (python ai_factory.py --cloud siliconflow)
# Получить: https://cloud.siliconflow.cn
SILICONFLOW_API_KEY=
# Together AI (python ai_factory.py --cloud together)
# Получить: https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# ── Модели ───────────────────────────────────────────────────────────────────
# Профили моделей настраиваются в models_pool.py (PROFILES dict).
# Выбор профиля при запуске: --local (по умолчанию) или --cloud <имя>
