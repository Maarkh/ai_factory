# ── Подключение к LLM (local бэкенд — всегда активен) ────────────────────────
LLM_BASE_URL=http://localhost:11434/v1/
LLM_API_KEY=ollama
LLM_TIMEOUT=300.0
LLM_MAX_TOKENS=16384
LLM_NUM_CTX=16384

# ── Пути и логирование ───────────────────────────────────────────────────────
PROJECT_BASE_DIR=/path/to/your/projects
LOG_LEVEL=INFO

# ── Дополнительные бэкенды (раскомментируйте и настройте) ────────────────────
# Формат: FACTORY_BACKEND_<NAME>_URL / _KEY / _TIMEOUT / _MAX_TOKENS / _NUM_CTX
#
# FACTORY_BACKEND_REMOTE_URL=http://work-server:11434/v1/
# FACTORY_BACKEND_REMOTE_KEY=ollama
# FACTORY_BACKEND_REMOTE_TIMEOUT=600.0
# FACTORY_BACKEND_REMOTE_MAX_TOKENS=32768
# FACTORY_BACKEND_REMOTE_NUM_CTX=32768

# ── Модель по умолчанию (fallback для всех агентов) ──────────────────────────
# FACTORY_DEFAULT_MODEL=deepseek-coder:6.7b

# ── Переопределение моделей и бэкендов по агентам ────────────────────────────
# FACTORY_MODEL_<AGENT>=model_name      — какую модель использовать
# FACTORY_BACKEND_<AGENT>=backend_name  — на каком бэкенде запускать (default: local)
#
# Пример: developer на удалённом сервере с 32B моделью
# FACTORY_MODEL_DEVELOPER=qwen2.5-coder:32b
# FACTORY_BACKEND_DEVELOPER=remote
#
# FACTORY_MODEL_DEVELOPER_PATCH=qwen2.5-coder:32b
# FACTORY_BACKEND_DEVELOPER_PATCH=remote
#
# FACTORY_MODEL_SELF_REFLECT=qwen3:32b
# FACTORY_BACKEND_SELF_REFLECT=remote
#
# Остальные агенты (без FACTORY_BACKEND_*) → local по умолчанию:
# FACTORY_MODEL_REVIEWER=deepseek-coder:6.7b
# FACTORY_MODEL_E2E_ARCHITECT=qwen3:latest
# FACTORY_MODEL_E2E_QA=qwen3:latest
# FACTORY_MODEL_QA_RUNTIME=deepseek-coder:6.7b
# FACTORY_MODEL_BUSINESS_ANALYST=qwen3:latest
# FACTORY_MODEL_SYSTEM_ANALYST=deepseek-coder:6.7b
# FACTORY_MODEL_ARCHITECT=deepseek-coder:6.7b
# FACTORY_MODEL_SPEC_REVIEWER=qwen3:latest
# FACTORY_MODEL_TEST_GENERATOR=deepseek-coder:6.7b
# FACTORY_MODEL_DOCUMENTER=qwen3:latest
# FACTORY_MODEL_DEVOPS_RUNTIME=qwen3:latest
# FACTORY_MODEL_ARCH_VALIDATOR=deepseek-coder:6.7b
# FACTORY_MODEL_SUPERVISOR=qwen3:latest
# FACTORY_MODEL_CONTRACT_ANALYST=deepseek-coder:6.7b
# FACTORY_MODEL_A5_VALIDATOR=deepseek-coder:6.7b
# FACTORY_MODEL_A5_BUSINESS_REVIEWER=qwen3:latest
# FACTORY_MODEL_A5_ARCHITECT_REVIEWER=qwen3:latest
# FACTORY_MODEL_A5_CONTRACT_REVIEWER=deepseek-coder:6.7b
