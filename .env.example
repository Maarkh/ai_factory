# ── Подключение к LLM (по умолчанию для всех агентов) ─────────────────────────
LLM_BASE_URL=http://localhost:11434/v1/
LLM_API_KEY=ollama
LLM_TIMEOUT=300.0
LLM_MAX_TOKENS=16384
LLM_NUM_CTX=16384

# ── Пути и логирование ───────────────────────────────────────────────────────
PROJECT_BASE_DIR=/path/to/your/projects
LOG_LEVEL=INFO

# ── Модели ───────────────────────────────────────────────────────────────────
# Конфигурация моделей (модель, сервер, ключ) — в файле models_pool.py.
# Откройте models_pool.py и замените _local() на _remote() для нужных агентов.
