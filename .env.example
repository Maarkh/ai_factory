# ── Подключение к LLM ────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:11434/v1/
LLM_API_KEY=ollama
LLM_TIMEOUT=300.0
LLM_MAX_TOKENS=16384
LLM_NUM_CTX=16384

# ── Пути и логирование ───────────────────────────────────────────────────────
PROJECT_BASE_DIR=/path/to/your/projects
LOG_LEVEL=INFO

# ── Модель по умолчанию (fallback для всех агентов) ──────────────────────────
# FACTORY_DEFAULT_MODEL=deepseek-coder:6.7b

# ── Переопределение моделей по агентам (раскомментируйте нужные) ─────────────
